
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# IDC Flare OAuth 配置
# 在 IDC Flare 开发者后台创建应用后获取以下信息
IDCFLARE_CLIENT_ID=
IDCFLARE_CLIENT_SECRET=
IDCFLARE_ISSUER=
IDCFLARE_AUTHORIZATION_URL=
IDCFLARE_TOKEN_URL=
IDCFLARE_USERINFO_URL=

# 数据库连接（Supabase Postgres）
# 在 Supabase 项目 Settings → Database → Connection string 中获取
DATABASE_URL=

# 站点 URL（用于回调地址等）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# 公众号草稿 & AI 封面图功能
# ─────────────────────────────────────────────────────────────────

# md2wechat：Markdown → 微信公众号 HTML 转换 & 草稿创建
# 获取 API Key：https://md2wechat.com → 注册账号 → API Keys
MD2WECHAT_API_KEY=
# md2wechat API 服务地址（必填！默认占位值不可用）
# 请登录 md2wechat 控制台或查阅文档确认实际 API Host，例如：
#   https://api.md2wechat.com   或   https://你的专属域名
# 填写格式：只填 Host，不带末尾斜杠，不带 /api/v1/...
MD2WECHAT_BASE_URL=

# 微信公众号：用于通过 md2wechat 创建草稿箱草稿
# 获取：微信公众平台 https://mp.weixin.qq.com → 设置与开发 → 基本配置
WECHAT_APPID=
WECHAT_APP_SECRET=

# 火山方舟（豆包）图片生成
# 获取 API Key：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# ARK_IMAGE_MODEL 填写模型 ID，例如：doubao-seedream-3-0-t2i-250415
ARK_API_KEY=
ARK_IMAGE_MODEL=

# 后台管理 Token（保护 /admin/publish 页面）
# 自定义一个随机强密码，在 Vercel 环境变量里设置同一个值
ADMIN_TOKEN=
