
# ═══════════════════════════════════════════════
# Zeno AI Home — 环境变量配置
# ═══════════════════════════════════════════════

# ── Auth 基础 ──
AUTH_SECRET=                    # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ── Supabase Postgres ──
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Google 登录 ──
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── 邮件验证码（Resend）──
RESEND_API_KEY=
EMAIL_FROM=Zeno <noreply@zenoaihome.com>

# ── 管理员后台（独立于用户登录）──
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=           # openssl rand -base64 32

# ── md2wechat 排版 API ──
MD2WECHAT_BASE_URL=
MD2WECHAT_API_KEY=
MD2WECHAT_CONVERT_ENDPOINT=
MD2WECHAT_DRAFT_ENDPOINT=
MD2WECHAT_UPLOAD_ENDPOINT=

# ── 微信公众号草稿箱 ──
WECHAT_APPID=
WECHAT_APP_SECRET=
WECHAT_DEFAULT_AUTHOR=Zeno
WECHAT_DEFAULT_COVER_MEDIA_ID=

# ── 豆包图片生成（火山引擎）──
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_IMAGE_MODEL=Doubao-Seedream-5.0-lite
VOLCENGINE_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_IMAGE_PRICE_PER_IMAGE=0.22

# ── 站点 URL ──
NEXT_PUBLIC_SITE_URL=https://zenoaihome.com
