
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# 数据库（Neon Serverless Postgres）
# 注册地址：https://neon.tech
# 创建项目后，在 Dashboard → Connection Details 中获取 Connection String
# 格式：postgresql://user:password@host/dbname?sslmode=require
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─────────────────────────────────────────────────────────────────
# 邮箱 Magic Link 登录（Resend）
# 注册地址：https://resend.com
# 1. 注册账号，创建 API Key
# 2. 在 Resend Domains 中验证 zenoaihome.com 域名（添加 DNS 记录）
# 3. 发件地址格式：Zeno 赞诺 <noreply@zenoaihome.com>
# ─────────────────────────────────────────────────────────────────
AUTH_RESEND_KEY=
EMAIL_FROM=Zeno 赞诺 <noreply@zenoaihome.com>

# ─────────────────────────────────────────────────────────────────
# 微信网页 OAuth（微信扫码登录）
# 和公众号 WECHAT_APPID 是不同的应用，需要在微信开放平台单独申请
# 注册地址：https://open.weixin.qq.com
# 申请「网站应用」，通过审核后获取 AppID 和 AppSecret
# 回调域名：zenoaihome.com
# 回调地址：https://zenoaihome.com/api/auth/callback/wechat
# ─────────────────────────────────────────────────────────────────
WECHAT_OPEN_CLIENT_ID=
WECHAT_OPEN_CLIENT_SECRET=

# 站点 URL（用于回调地址等）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# 公众号草稿 & AI 封面图功能
# ─────────────────────────────────────────────────────────────────

# md2wechat：Markdown → 微信公众号 HTML 转换 & 草稿创建
# API Key 购买后在 md2wechat.cn 控制台获取
MD2WECHAT_API_KEY=
# md2wechat API 服务地址（填写 Host，不带末尾斜杠）
# 例如：https://md2wechat.cn 或 https://md2wechat.app
MD2WECHAT_BASE_URL=
# 以下 endpoint 为可选覆盖，留空则使用默认值 /api/v1/convert 和 /api/v1/article-draft
MD2WECHAT_CONVERT_ENDPOINT=
MD2WECHAT_DRAFT_ENDPOINT=
MD2WECHAT_UPLOAD_ENDPOINT=

# 微信公众号：AppID 和 AppSecret
# 获取：微信公众平台 → 设置与开发 → 基本配置
WECHAT_APPID=
WECHAT_APP_SECRET=
WECHAT_DEFAULT_AUTHOR=Zeno
# 默认封面图 media_id（在微信公众号素材库上传图片后获取）
WECHAT_DEFAULT_COVER_MEDIA_ID=

# 火山引擎豆包图片生成
# API Key 在：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLCENGINE_ARK_API_KEY=
# 模型 ID（从控制台确认后填入，当前使用 Doubao-Seedream-5.0-lite）
VOLCENGINE_IMAGE_MODEL=Doubao-Seedream-5.0-lite
# API 基础地址（默认不用改）
VOLCENGINE_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 单张图片预估成本（元），用于前端显示，不影响实际计费
VOLCENGINE_IMAGE_PRICE_PER_IMAGE=0.22

# 管理员邮箱（逗号分隔），拥有草稿推送和图片生成权限
# 例如：admin@example.com,other@example.com
# 如果 OAuth 返回的是隐私邮箱，可以把隐私邮箱也填进来
ADMIN_EMAILS=

# 管理员用户 ID（逗号分隔）
# 适用于 OAuth 返回隐私邮箱的情况（如 IDC Flare）
# 打开 /account 页面，复制「用户 ID」后填入
# 例如：abc123,def456
ADMIN_USER_IDS=

# 后台管理 Token（保护旧版 /admin/publish 页面）
ADMIN_TOKEN=
