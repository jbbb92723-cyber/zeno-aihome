// Supabase Postgres + Prisma
// Auth.js v5 兼容 + 邮箱注册 + 验证码

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── 用户 ─────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  membership     Membership?
  resourceClaims ResourceClaim[]
  serviceRequests ServiceRequest[]

  @@map("users")
}

// ─── OAuth 账号关联（Google 等）─────────────────────────────
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

// ─── Session（Auth.js 需要，JWT 模式下基本不写入）──────────
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

// ─── Auth.js 验证令牌（内部用，非邮箱验证码）──────────────
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── 邮箱验证码（注册 / 重置密码 / 修改密码）──────────────
model VerificationCode {
  id         String   @id @default(cuid())
  email      String
  codeHash   String
  type       String   // register | reset_password | change_password
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([email, type])
  @@map("verification_codes")
}

// ─── 会员资格 ───────────────────────────────────────────────
model Membership {
  id        String    @id @default(cuid())
  userId    String    @unique
  plan      String    @default("free")   // free | creator
  status    String    @default("active") // active | expired | cancelled
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

// ─── 资料领取记录 ───────────────────────────────────────────
model ResourceClaim {
  id            String   @id @default(cuid())
  userId        String
  resourceId    String
  resourceTitle String
  resourceUrl   String?
  claimedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resource_claims")
}

// ─── 服务申请记录 ───────────────────────────────────────────
model ServiceRequest {
  id          String   @id @default(cuid())
  userId      String?
  serviceType String
  name        String?
  phone       String?
  wechat      String?
  email       String?
  message     String?
  status      String   @default("submitted") // submitted | reviewing | completed | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("service_requests")
}
